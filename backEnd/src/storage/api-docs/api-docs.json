    "components": {
        "schemas": {
            "UserRequest": {
                "title": "User Request",
                "description": "Request schema for creating or updating a user",
                "required": [
                    "name",
                    "email",
                    "password"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    },
                    "bio": {
                        "type": "string",
                        "example": "This is John's bio"
                    },
                    "profileImage": {
                        "type": "string",
                        "format": "uri",
                        "example": "http://example.com/john.jpg"
                    },
                    "bannerImage": {
                        "type": "string",
                        "format": "uri",
                        "example": "http://example.com/john.jpg"
                    },
                    "role": {
                        "type": "string",
                        "example": "JOUEUR",
                        "enum": [
                            "JOUEUR",
                            "CLUB_ADMIN"
                        ]
                    }
                },
                "type": "object"
            },
            "ConversationResource": {
                "title": "Conversation Resource",
                "description": "Resource representation of a Conversation",
                "properties": {
                    "user": {
                        "$ref": "#/components/schemas/UserResource"
                    },
                    "messages": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MessageResource"
                        }
                    }
                },
                "type": "object"
            },
            "MessageResource": {
                "title": "Message Resource",
                "description": "Resource representation of a Message",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "sender_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "receiver_id": {
                        "type": "integer",
                        "example": 2
                    },
                    "message": {
                        "type": "string",
                        "example": "Hello, how are you?"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-01T12:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-02T12:00:00Z"
                    }
                },
                "type": "object"
            },
            "UserResource": {
                "title": "User Resource",
                "description": "Resource representation of a User",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "example": "john@example.com"
                    },
                    "bio": {
                        "type": "string",
                        "example": "This is John's bio"
                    },
                    "profileImage": {
                        "type": "string",
                        "example": "http://localhost:8081/storage/profile_images/john.jpg"
                    },
                    "bannerImage": {
                        "type": "string",
                        "example": "http://localhost:8081/storage/banner_images/john.jpg"
                    },
                    "role": {
                        "type": "string",
                        "example": "Joueur"
                    },
                    "isActive": {
                        "type": "boolean",
                        "example": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-01T12:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-01-02T12:00:00Z"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Authentication"
        },
        {
            "name": "Users",
            "description": "Users"
        },
        {
            "name": "Messages",
            "description": "Messages"
        },
        {
            "name": "Follows",
            "description": "Follows"
        }
    ]
}